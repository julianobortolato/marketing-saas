# Supabase — obter no Dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=<COLE_AQUI: Project Settings → API → Project URL>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<COLE_AQUI: Project Settings → API → Project API keys → anon public>
SUPABASE_SERVICE_ROLE_KEY=<COLE_AQUI: Project Settings → API → Project API keys → service_role (NUNCA expor no cliente)>

# OpenAI — não desce via vercel env pull
OPENAI_API_KEY=<COLE_AQUI>

# Evolution API
EVOLUTION_API_URL=<COLE_AQUI>
EVOLUTION_API_KEY=<COLE_AQUI>

# Crons — variável de sistema Vercel, não desce via pull
CRON_SECRET=<COLE_AQUI>

# Webhook de leads — Phase 2
# LEADS_WEBHOOK_SECRET: segredo HMAC compartilhado com a origem do webhook (Meta/WhatsApp)
LEADS_WEBHOOK_SECRET=<COLE_AQUI>
# WEBHOOK_TENANT_MAP: JSON mapeando token → tenant_uuid
# Token: escolha uma string aleatória e configure no lado da origem do webhook
# tenant_uuid: ID do tenant Fitness UNIC em public.tenants (SELECT id FROM public.tenants;)
WEBHOOK_TENANT_MAP={"<COLE_AQUI_TOKEN>":"<COLE_AQUI_TENANT_UUID>"}

# Opcional — bridge IARA Systems
# IARA_SUPABASE_URL=
# IARA_SERVICE_ROLE_KEY=
